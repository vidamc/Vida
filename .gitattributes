# Default: auto-normalize line endings
* text=auto eol=lf

# Windows-specific scripts
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Shell scripts
*.sh      text eol=lf
gradlew   text eol=lf

# Binary files
*.jar     binary
*.class   binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ctg     binary

# Source files
*.java    text diff=java
*.kt      text diff=kotlin
*.kts     text diff=kotlin
*.gradle  text
*.md      text diff=markdown
*.json    text
*.toml    text
*.yml     text
*.yaml    text
